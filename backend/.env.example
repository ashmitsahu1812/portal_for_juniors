# ─── Environment Variables ─────────────────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# MongoDB Atlas connection string (or local: mongodb://localhost:27017/lms_db)
MONGO_URI=mongodb://localhost:27017/lms_db

# Server port (5001 avoids conflict with macOS AirPlay Receiver on port 5000)
PORT=5001

# Node environment: development | production
NODE_ENV=development

# Comma-separated list of frontend origins allowed by CORS
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Piston API (default: public hosted, no key needed) ────────────────────────
PISTON_API_URL=https://emkc.org/api/v2/piston

# ── Judge0 (optional alternative — comment out Piston above) ──────────────────
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key_here
